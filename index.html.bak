                        <span>Referral rewards (earn free months)</span>
                    </div>
                </div>
                
                <form class="email-form" onsubmit="handleWaitlist(event)">
                    <input type="email" id="email-waitlist" class="input" placeholder="you@example.com" required>
                    <button type="submit" class="btn btn-primary">Join the Waitlist</button>
                </form>
                
                <div class="form-optional">
                    <p>Optional — Help us build something you'll love:</p>
                    <div class="checkbox-group">
                        <label><input type="checkbox" name="interest" value="mental-health"> Mental health tracking</label>
                        <label><input type="checkbox" name="interest" value="chronic-illness"> Chronic illness management</label>
                        <label><input type="checkbox" name="interest" value="fertility"> Fertility tracking</label>
                        <label><input type="checkbox" name="interest" value="wellness"> General wellness & self-care</label>
                        <label><input type="checkbox" name="interest" value="bujo"> Bullet journal lover</label>
                        <label><input type="checkbox" name="interest" value="beta"> I'd like to beta test (iOS, Australia only)</label>
                    </div>
                </div>
                
                <p class="email-note">Your email stays private. Unsubscribe anytime. We only email for real updates.</p>
            </div>
        </div>
    </section>

