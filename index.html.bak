            <div class="entry-demo">
                <h3>How's your mood today?</h3>
                <div class="sticker-row">
                    <div class="sticker-demo">
                        <div class="sticker-mood sticker-great">
                            <div class="blush left"></div>
                            <div class="blush right"></div>
                            <div class="face">
                                <div class="eyes"><div class="eye-squinty"></div><div class="eye-squinty"></div></div>
                                <div class="mouth-d"></div>
                            </div>
                        </div>
                        <span class="sticker-label">Great</span>
                    </div>
                    <div class="sticker-demo">
                        <div class="sticker-mood sticker-good">
                            <div class="blush left"></div>
                            <div class="blush right"></div>
                            <div class="face">
                                <div class="eyes"><div class="eye-squinty"></div><div class="eye-squinty"></div></div>
                                <div class="mouth-smile"></div>
                            </div>
                        </div>
                        <span class="sticker-label">Good</span>
                    </div>
                    <div class="sticker-demo">
                        <div class="sticker-mood sticker-okay">
                            <div class="blush left"></div>
                            <div class="blush right"></div>
                            <div class="face">
                                <div class="eyes"><div class="eye-dot"></div><div class="eye-dot"></div></div>
                                <div class="mouth-flat"></div>
                            </div>
                        </div>
                        <span class="sticker-label">Okay</span>
                    </div>
                    <div class="sticker-demo">
                        <div class="sticker-mood sticker-low">
                            <div class="face">
                                <div class="eyes"><div class="eye-sad"></div><div class="eye-sad"></div></div>
                                <div class="mouth-small-frown"></div>
