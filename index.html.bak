                <form class="email-form" onsubmit="handleSubmit(event)">
                    <input type="email" id="email-pdf" class="input" placeholder="you@example.com" required>
                    <button type="submit" class="btn btn-primary">Send me the PDFs</button>
                </form>
                
                <p class="email-note">No spam. One delivery email, then optional updates. Unsubscribe anytime.</p>
                <p class="email-license">Personal use + classroom/clinic printing allowed. Not for resale or redistribution.</p>
            </div>
        </div>
    </section>

